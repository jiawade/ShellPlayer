<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:background="@drawable/widget_bg">

    <!-- Album art -->
    <ImageView
        android:id="@+id/widget_artwork"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher_round"
        android:contentDescription="Album Art"
        android:clipToOutline="true"
        android:background="@drawable/widget_artwork_bg" />

    <!-- Song info + progress + controls -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <!-- Title + Controls row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Song info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Music X"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Not Playing"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- Playback controls -->
            <ImageView
                android:id="@+id/widget_prev"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_widget_prev"
                android:contentDescription="Previous"
                android:scaleType="centerInside"
                android:background="@drawable/widget_btn_ripple" />

            <ImageView
                android:id="@+id/widget_play_pause"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_widget_play"
                android:contentDescription="Play/Pause"
                android:scaleType="centerInside"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_play_btn_bg" />

            <ImageView
                android:id="@+id/widget_next"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_widget_next"
                android:contentDescription="Next"
                android:scaleType="centerInside"
                android:background="@drawable/widget_btn_ripple" />
        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/widget_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="6dp"
            android:max="1000"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress_drawable" />
    </LinearLayout>
</LinearLayout>
