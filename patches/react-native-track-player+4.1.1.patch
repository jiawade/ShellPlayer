+    /**
+     * 暴露 ExoPlayer 的 audioSessionId 给外部模块（AudioLevel / Equalizer）。
+     * 返回 >0 表示播放器已就绪，0 表示未初始化。
+     */
+    fun getAudioSessionId(): Int {
+        if (!this::player.isInitialized) return 0
+        return try {
+            // getExoPlayer() is protected — access via reflection
+            val method = player.javaClass.superclass?.getDeclaredMethod("getExoPlayer")
+            method?.isAccessible = true
+            val exo = method?.invoke(player) as? com.google.android.exoplayer2.ExoPlayer
+            exo?.audioSessionId ?: 0
+        } catch (_: Exception) {
+            0
+        }
+    }
