 @objc(RNTrackPlayer)
 public class RNTrackPlayer: RCTEventEmitter, AudioSessionControllerDelegate {
+
+    /// Exposed for EqualizerModule / AudioMeter: returns current AVPlayerItem for tap application.
+    /// Uses KVC to reach the internal AVPlayer because SwiftAudioEx's wrapper is module-internal.
+    @objc public func getCurrentAVPlayerItem() -> AVPlayerItem? {
+        let mirror = Mirror(reflecting: player)
+        // AudioPlayer.wrapper (internal let)
+        guard let wrapper = mirror.descendant("wrapper") else { return nil }
+        let wrapperMirror = Mirror(reflecting: wrapper)
+        // AVPlayerWrapper.avPlayer (fileprivate var)
+        guard let avPlayer = wrapperMirror.descendant("avPlayer") as? AVPlayer else { return nil }
+        return avPlayer.currentItem
+    }
 
